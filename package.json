{
  "name": "agent-stash",
  "version": "0.1.0",
  "description": "Stash cold local AI coding-agent sessions with byte-exact restore.",
  "license": "MIT",
  "keywords": [
    "ai-agents",
    "coding-agents",
    "sessions",
    "compression",
    "cli",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YosefHayim/agent-recall.git"
  },
  "bugs": {
    "url": "https://github.com/YosefHayim/agent-recall/issues"
  },
  "homepage": "https://github.com/YosefHayim/agent-recall#readme",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "bin": {
    "agent-stash": "dist/cli/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "examples"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/cli/main.ts",
    "health": "tsx src/cli/main.ts doctor",
    "scan": "tsx src/cli/main.ts scan",
    "savings": "tsx src/cli/main.ts savings",
    "pack:dry-run": "tsx src/cli/main.ts pack --dry-run",
    "evidence": "tsx src/cli/main.ts savings",
    "build": "tsup",
    "check:ci": "biome ci . && eslint .",
    "test": "vitest run",
    "test:integration": "vitest run tests/*.integration.test.ts",
    "typecheck": "tsc --noEmit",
    "evidence:local": "tsx src/cli/main.ts savings"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^24.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "tsup": "^8.5.1",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.62.1",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "citty": "^0.2.2",
    "effect": "^3.21.4"
  }
}
